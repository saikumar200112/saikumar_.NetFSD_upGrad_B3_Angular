@model Products

<h2>Create Employee</h2>
<hr />


<form method="post" asp-action="Add">

    <div class="form-group">
        <label asp-for="PId" class="form-label"></label>
        <input asp-for="PId" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Pname" class="form-label"></label>
        <input asp-for="Pname" class="form-control" />
    </div>
 
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
    </div>
    

    <button type="submit" class="btn btn-success">AddProduct</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    
</form>