@model IEnumerable<Course>

<table class="table">

    <tr>
        <th>Course Id</th>
        <th>Course Name</th>
        <th>Students</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CourseId</td>
            <td>@item.CourseName</td>
            <td>

                <ul>
                    @foreach (var std in item.Students)
                    {
                        <li>@std.StudentName</li>
                    }
                </ul>

            </td>

        </tr>
    }

</table>
