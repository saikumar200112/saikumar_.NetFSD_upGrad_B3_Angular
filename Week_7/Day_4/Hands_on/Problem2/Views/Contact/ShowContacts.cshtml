@model IEnumerable<ContactInfo>

<h2>Contact List</h2>
<a asp-action="AddContact" class="btn btn-success mb-3">Add New Contact</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Designation</th>
            <th>Company</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FirstName @item.LastName</td>
                <td>@item.EmailId</td>
                <td>@item.Designation</td>
                <td>@item.Company?.CompanyName</td>
                <td>@item.Department?.DepartmentName</td>
                <td>
                    <a asp-action="EditContact" asp-route-id="@item.ContactId" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-action="DeleteContact" asp-route-id="@item.ContactId"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Are you sure?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>